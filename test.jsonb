{
    "bmc": {
        "fw":   "{{ ipmitool bmc info 2>&1 | awk '
            /Firmware Revision/     { fw=$NF }
            /Aux Firmware Rev Info/ { found=1; next }
            found && /0x/           { aux=strtonum($1); found=0 }
            END { printf "%s.%02d", fw, aux }
        ' }}",
        "ipmi": "{{ ipmitool bmc info 2>&1 | awk '/IPMI Version/ { print $NF }' }}"
    }
}